# Frontend/Public Runtime
# In production, prefer same-origin API routing with /api
VITE_API_URL=/api
# Optional: explicitly point frontend to Convex origin
VITE_CONVEX_URL=
# Public app origin used for checkout/password reset redirects
VITE_APP_URL=https://koreanstudy.me
# Frontend Sentry DSN (optional but recommended in production)
VITE_SENTRY_DSN=

# Convex/Core Runtime
CONVEX_DEPLOYMENT=prod:your-convex-deployment
CONVEX_SITE_URL=https://your-convex-site.convex.cloud
CONVEX_URL=https://your-convex-site.convex.cloud
SITE_URL=https://koreanstudy.me
NODE_ENV=production
# Backend Sentry DSN (recommended in production)
SENTRY_DSN=

# Auth Configuration
# Comma-separated list of allowed origins for auth redirects
AUTH_ALLOWED_ORIGINS=https://koreanstudy.me,https://www.koreanstudy.me,http://localhost:5173,http://localhost:3000

# AI/Transcription
MIMO_API_KEY=
MIMO_API_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_CHAT_MODEL=mimo-v2-flash
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
PODCASTINDEX_API_KEY=
PODCASTINDEX_API_SECRET=
PODCASTINDEX_API_BASE_URL=https://api.podcastindex.org/api/1.0
# AI action safeguards
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_CALLS=120

# Dictionary Provider
KRDICT_API_KEY=

# Email/Password Reset
RESEND_API_KEY=
EMAIL_FROM=noreply@koreanstudy.me

# Object Storage (Spaces/S3 compatible)
SPACES_ENDPOINT=
SPACES_REGION=
SPACES_BUCKET=
SPACES_KEY=
SPACES_SECRET=
SPACES_CDN_URL=

# Azure Speech (TTS fallback)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# PDF export assets (Convex action)
PDF_FONT_LATIN_URL=https://joyhan.sgp1.cdn.digitaloceanspaces.com/fonts/NotoSans-Regular.ttf
PDF_FONT_SC_URL=https://joyhan.sgp1.cdn.digitaloceanspaces.com/fonts/NotoSansSC-Regular.ttf
PDF_FONT_KR_URL=https://joyhan.sgp1.cdn.digitaloceanspaces.com/fonts/NotoSansKR-Regular.ttf
PDF_LOGO_URL=https://joyhan.sgp1.cdn.digitaloceanspaces.com/fonts/IMG_8911%E5%B0%8F.png

# Creem Payments
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_TEST_MODE=true
CREEM_PRODUCT_MONTHLY=
CREEM_PRODUCT_SEMIANNUAL=
CREEM_PRODUCT_QUARTERLY=
CREEM_PRODUCT_ANNUAL=
CREEM_PRODUCT_LIFETIME=

# LemonSqueezy Payments
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_MONTHLY=
LEMONSQUEEZY_VARIANT_SEMIANNUAL=
LEMONSQUEEZY_VARIANT_QUARTERLY=
LEMONSQUEEZY_VARIANT_ANNUAL=
LEMONSQUEEZY_VARIANT_LIFETIME=
LEMONSQUEEZY_VARIANT_MONTHLY_REGIONAL=
LEMONSQUEEZY_VARIANT_SEMIANNUAL_REGIONAL=
LEMONSQUEEZY_VARIANT_QUARTERLY_REGIONAL=
LEMONSQUEEZY_VARIANT_ANNUAL_REGIONAL=
LEMONSQUEEZY_VARIANT_LIFETIME_REGIONAL=
