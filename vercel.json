    },
    {
      "source": "/:path((?!en|zh|vi|mn|api|_next|static|favicon.ico|logo.png|sitemap.xml|robots.txt|locales|assets).*)/",
      "destination": "/en/:path",
      "permanent": true
    },
    {
      "source": "/:path((?!en|zh|vi|mn|api|_next|static|favicon.ico|logo.png|sitemap.xml|robots.txt|locales|assets).*)",
      "destination": "/en/:path",
      "permanent": true
    },
    {
      "source": "/:path((?!api|_next|static|favicon.ico|logo.png|sitemap.xml|robots.txt|locales|assets).*)/",
      "destination": "/:path",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/locales/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' https://apis.google.com https://*.convex.cloud; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://*.convex.cloud https://lh3.googleusercontent.com; connect-src 'self' https://*.convex.cloud https://api.convex.dev https://fonts.googleapis.com https://fonts.gstatic.com https://ipapi.co https://ipwho.is; frame-src 'self' https://*.convex.cloud https://accounts.google.com;"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
