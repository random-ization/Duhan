      "destination": "/vi",
      "permanent": true
    },
    {
      "source": "/VI/:path*",
      "destination": "/vi/:path*",
      "permanent": true
    },
    {
      "source": "/Vi/:path*",
      "destination": "/vi/:path*",
      "permanent": true
    },
