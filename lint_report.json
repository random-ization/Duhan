: user,\n          examId: exam,\n          score: 90,\n          totalQuestions: 10,\n          duration: 1200,\n          accuracy: 90,\n          sessionId: 'session-delete',\n          userAnswers: { '1': 0 },\n          createdAt: Date.now(),\n        });\n\n        return attempt;\n      });\n\n      const result = await test.mutation(api.exams.deleteAttempt, {\n        attemptId,\n      });\n\n      expect(result.success).toBe(true);\n    });\n  });\n\n  describe('Mistake Tracking', () => {\n    it('should save mistake', async () => {\n      const userId = await test.run(async (ctx) => {\n        // Create a test user\n        const user = await ctx.db.insert('users', {\n          email: 'mistake@example.com',\n          name: 'Mistake User',\n          role: 'STUDENT',\n          accountStatus: 'ACTIVE',\n          isVerified: false,\n          kycStatus: 'NONE',\n          tier: 'FREE',\n          createdAt: Date.now(),\n          lastActivityAt: Date.now(),\n        });\n\n        return user;\n      });\n\n      const result = await test.withIdentity(userId).mutation(api.mistakes.save, {\n        word: '어려워',\n        meaning: 'Difficult',\n        mistakeType: 'pronunciation',\n        context: 'I thought it was pronounced differently',\n        correction: 'The correct pronunciation is...',\n      });\n\n      expect(result.success).toBe(true);\n      expect(result.mistakeId).toBeDefined();\n    });\n\n    it('should get user mistakes', async () => {\n      const userId = await test.run(async (ctx) => {\n        // Create a test user\n        const user = await ctx.db.insert('users', {\n          email: 'mistakes@example.com',\n          name: 'Mistakes User',\n          role: 'STUDENT',\n          accountStatus: 'ACTIVE',\n          isVerified: false,\n          kycStatus: 'NONE',\n          tier: 'FREE',\n          createdAt: Date.now(),\n          lastActivityAt: Date.now(),\n        });\n\n        // Create some mistakes\n        await ctx.db.insert('mistakes', {\n          userId: user,\n          word: '어려워',\n          meaning: 'Difficult',\n          mistakeType: 'pronunciation',\n          context: 'Practice session',\n          correction: 'Correct pronunciation',\n          createdAt: Date.now() - 3600000,\n        });\n\n        await ctx.db.insert('mistakes', {\n          userId: user,\n          word: '감사합니다',\n          meaning: 'Thank you',\n          mistakeType: 'usage',\n          context: 'Writing exercise',\n          correction: 'Better usage',\n          createdAt: Date.now() - 1800000,\n        });\n\n        return user;\n      });\n\n      const result = await test.withIdentity(userId).query(api.mistakes.list, {\n        limit: 10,\n      });\n\n      expect(result).toHaveLength(2);\n      expect(result[0].word).toBe('감사합니다'); // Most recent first\n      expect(result[1].word).toBe('어려워');\n    });\n\n    it('should clear all mistakes', async () => {\n      const userId = await test.run(async (ctx) => {\n        // Create a test user\n        const user = await ctx.db.insert('users', {\n          email: 'clear@example.com',\n          name: 'Clear User',\n          role: 'STUDENT',\n          accountStatus: 'ACTIVE',\n          isVerified: false,\n          kycStatus: 'NONE',\n          tier: 'FREE',\n          createdAt: Date.now(),\n          lastActivityAt: Date.now(),\n        });\n\n        // Create some mistakes\n        await ctx.db.insert('mistakes', {\n          userId: user,\n          word: '어려워',\n          meaning: 'Difficult',\n          mistakeType: 'pronunciation',\n          context: 'Practice session',\n          correction: 'Correct pronunciation',\n          createdAt: Date.now(),\n        });\n\n        await ctx.db.insert('mistakes', {\n          userId: user,\n          word: '감사합니다',\n          meaning: 'Thank you',\n          mistakeType: 'usage',\n          context: 'Writing exercise',\n          correction: 'Better usage',\n          createdAt: Date.now(),\n        });\n\n        return user;\n      });\n\n      const result = await test.withIdentity(userId).mutation(api.mistakes.clear);\n\n      expect(result.success).toBe(true);\n      expect(result.deletedCount).toBe(2);\n    });\n  });\n});\n","usedDeprecatedRules":[]},{"filePath":"/Users/ryan/Documents/GitHub/hangyeol/tests/convex/notePages.test.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'beforeEach' is defined but never used.","line":1,"column":32,"nodeType":"Identifier","messageId":"unusedVar","endLine":1,"endColumn":42,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"beforeEach"},"fix":{"range":[29,41],"text":""},"desc":"Remove unused variable \"beforeEach\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'afterAll' is defined but never used.","line":1,"column":55,"nodeType":"Identifier","messageId":"unusedVar","endLine":1,"endColumn":63,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"afterAll"},"fix":{"range":[52,62],"text":""},"desc":"Remove unused variable \"afterAll\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ConvexFunction' is defined but never used.","line":3,"column":15,"nodeType":"Identifier","messageId":"unusedVar","endLine":3,"endColumn":29,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"ConvexFunction"},"fix":{"range":[122,174],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'userId' is assigned a value but never used.","line":15,"column":13,"nodeType":"Identifier","messageId":"unusedVar","endLine":15,"endColumn":19},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'userId' is assigned a value but never used.","line":67,"column":13,"nodeType":"Identifier","messageId":"unusedVar","endLine":67,"endColumn":19},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'userId' is as